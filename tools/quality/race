set -euo pipefail

repo_root=$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)
cd "$repo_root"

packages=("$@")
if ((${#packages[@]} == 0)); then
  packages=(./...)
fi

echo "==> go test -race ${packages[*]}"
go test -race "${packages[@]}"
