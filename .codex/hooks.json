{
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/python3 \"$(git rev-parse --show-toplevel)/.codex/hooks/stop_repo_state.py\"",
            "timeout": 30,
            "statusMessage": "Checking yeet repo state"
          }
        ]
      }
    ]
  }
}
